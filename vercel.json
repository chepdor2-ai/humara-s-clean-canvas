{
  "framework": "nextjs",
  "buildCommand": "cd humanizer-engine/frontend && npm run build",
  "installCommand": "npm install --ignore-scripts && cd humanizer-engine/frontend && npm install --include=dev",
  "outputDirectory": "humanizer-engine/frontend/.next",
  "devCommand": "cd humanizer-engine/frontend && npm run dev",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
